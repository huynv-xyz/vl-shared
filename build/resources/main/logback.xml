<configuration>
    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>


    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">

            <!-- Static fields (good for prod). Values can come from env/system properties. -->
            <!-- If missing, they’ll be empty or default. -->
            <globalCustomFields>
                {
                "app":"${APP_NAME:-unknown-app}",
                "env":"${ENV:-unknown-env}",
                "version":"${APP_VERSION:-unknown-version}",
                "pod":"${HOSTNAME:-unknown-pod}"
                }
            </globalCustomFields>

            <providers>
                <timestamp>
                    <fieldName>time</fieldName>
                </timestamp>

                <logLevel>
                    <fieldName>level</fieldName>
                </logLevel>

                <threadName>
                    <fieldName>thread</fieldName>
                </threadName>

                <loggerName>
                    <fieldName>logger</fieldName>
                </loggerName>

                <message>
                    <fieldName>msg</fieldName>
                </message>

                <!-- Whitelisted MDC keys only (production-safe) -->
                <mdc>
                    <!-- tracing -->
                    <includeMdcKeyName>traceId</includeMdcKeyName>
                    <includeMdcKeyName>requestId</includeMdcKeyName>

                    <!-- business/context -->
                    <includeMdcKeyName>userId</includeMdcKeyName>
                    <includeMdcKeyName>fromSource</includeMdcKeyName>
                    <includeMdcKeyName>fromIp</includeMdcKeyName>
                    <includeMdcKeyName>clientIp</includeMdcKeyName>

                    <!-- rpc semantic -->
                    <includeMdcKeyName>protocol</includeMdcKeyName>
                    <includeMdcKeyName>service</includeMdcKeyName>
                    <includeMdcKeyName>operation</includeMdcKeyName>

                    <!-- outcome -->
                    <includeMdcKeyName>status</includeMdcKeyName>
                    <includeMdcKeyName>exception</includeMdcKeyName>
                </mdc>

                <stackTrace>
                    <fieldName>stacktrace</fieldName>
                    <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                        <maxDepthPerThrowable>30</maxDepthPerThrowable>
                        <maxLength>8192</maxLength>
                        <rootCauseFirst>true</rootCauseFirst>
                    </throwableConverter>
                </stackTrace>
            </providers>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
